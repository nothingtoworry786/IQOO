# ── Supabase (new stack) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SerpAPI (optional — signals degrade gracefully without it) ────────────────
SERPAPI_KEY=

# ── ChromaDB (local vector store) ────────────────────────────────────────────
CHROMADB_PATH=./chromadb_data

# ── Legacy AI provider (existing endpoints) ───────────────────────────────────
AI_PROVIDER=anthropic
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Legacy database (SQLite for existing endpoints) ───────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./marketwatch.db
