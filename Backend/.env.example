# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────
# SQLite for dev, PostgreSQL+pgvector for production (Supabase)
DATABASE_URL=sqlite+aiosqlite:///./marketwatch.db

# ── AI Provider ───────────────────────────────────────────
# Options: groq | openrouter | anthropic
AI_PROVIDER=groq

# ── Groq ──────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenRouter ────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Anthropic (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
